# Copie para .env.local e preencha (não commite segredos).
# Supabase: Settings → API no dashboard do projeto
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Servidor apenas — nunca use NEXT_PUBLIC_ para estas chaves
# Service role: Settings → API → service_role (bypass RLS nas rotas /api/todos)
SUPABASE_SERVICE_ROLE_KEY=

# API externa (job Python / agente Michelangelo): header x-api-key
# Gere com: openssl rand -hex 32
TASK_ARCHITECT_API_KEY=

# UUID do utilizador auth.users cujas tarefas estas rotas podem ler/escrever
TASK_ARCHITECT_USER_ID=

# Opcional: origem CORS (default *). Ex.: https://teu-vps.exemplo.com
# TASK_ARCHITECT_CORS_ORIGIN=*

# Servidor apenas (legado)
GEMINI_API_KEY=
